      "content": "File: src/main.ts (120 lines) [hash:ae7078a0]\n1|/**\r\n2| * Apify Actor entry point for immobiliare.it scraping.\r\n3| * \r\n4| * Reads `citta` (city) and `quartiere` (neighborhood) from input and extracts\r\n5| * all listing URLs using a step-by-step Playwright approach with manual pagination.\r\n6| * Results are pushed to the Apify Dataset.\r\n7| * \r\n8| * Proxy support is enabled via Actor.createProxyConfiguration().\r\n9| * Screenshots are saved to logs/{citta}/screenshots/ on errors.\r\n10| */\r\n11|\r\n12|import { Actor } from 'apify';\r\n13|import { chromium } from 'playwright';\r\n14|import { scrapeImmobiliare } from './immobiliare-scraper.js';\r\n15|\r\n16|// Initialize the Apify SDK\r\n17|await Actor.init();\r\n18|\r\n19|interface Input {\r\n20|  citta: string;\r\n21|  quartiere: string;\r\n22|}\r\n23|\r\n24|// Read input\r\n25|const input = await Actor.getInput<Input>();\r\n26|if (!input) {\r\n27|  throw new Error('No input provided. Expected { citta: string, quartiere: string }');\r\n28|}\r\n29|\r\n30|const { citta, quartiere } = input;\r\n31|\r\n32|// Validate required fields\r\n33|if (!citta || typeof citta !== 'string' || citta.trim().length === 0) {\r\n34|  throw new Error('Input must contain a non-empty \"citta\" string (city name, lowercase, no accents).');\r\n35|}\r\n36|if (!quartiere || typeof quartiere !== 'string' || quartiere.trim().length === 0) {\r\n37|  throw new Error('Input must contain a non-empty \"quartiere\" string (neighborhood name).');\r\n38|}\r\n39|\r\n40|// Normalize: remove accents and convert to lowercase\r\n41|const normalize = (s: string): string =>\r\n42|  s.normalize('NFD').replace(/\\p{M}/gu, '').toLowerCase();\r\n43|\r\n44|const cittaNorm = normalize(citta.trim());\r\n45|const quartiereNorm = normalize(quartiere.trim());\r\n46|\r\n47|console.log(`[main] Starting scraping for ${cittaNorm}/${quartiereNorm}`);\r\n48|\r\n49|// Ensure log directory exists\r\n50|import { mkdirSync } from 'node:fs';\r\n51|const logDir = `logs/${cittaNorm}`;\r\n52|mkdirSync(logDir, { recursive: true });\r\n53|console.log(`[main] Log directory: ${logDir}`);\r\n54|\r\n55|// Proxy configuration\r\n56|const proxyConfig = await Actor.createProxyConfiguration({\r\n57|  // Disable access check for faster startup (assume valid config)\r\n58|  checkAccess: false,\r\n59|});\r\n60|\r\n61|let proxyUrl: string | undefined;\r\n62|if (proxyConfig) {\r\n63|  try {\r\n64|    proxyUrl = await proxyConfig.newUrl();\r\n65|    console.log(`[main] Using proxy: ${proxyUrl}`);\r\n66|  } catch {\r\n67|    console.warn('[main] Could not get proxy URL, proceeding without proxy');\r\n68|  }\r\n69|}\r\n70|\r\n71|// Launch browser with proxy support\r\n72|const launchOptions: Parameters<typeof chromium.launch>[0] = {\r\n73|  headless: true,\r\n74|  args: [\r\n75|    '--disable-gpu',                    // Mitigates GPU crashes in Docker\r\n76|    '--disable-blink-features=Automation', // Avoid bot detection\r\n77|  ],\r\n78|};\r\n79|\r\n80|if (proxyUrl) {\r\n81|  launchOptions.proxy = { server: proxyUrl };\r\n82|}\r\n83|\r\n84|console.log('[main] Launching Chromium browser...');\r\n85|const browser = await chromium.launch(launchOptions);\r\n86|\r\n87|// Shared data dictionary (populated by scraper)\r\n88|const data: Record<string, Record<string, string[]>> = {};\r\n89|\r\n90|try {\r\n91|  // Call the step-by-step scraper\r\n92|  await scrapeImmobiliare({ browser, citta: cittaNorm, quartiere: quartiereNorm, data });\r\n93|\r\n94|  // Collect results from the shared dictionary\r\n95|  const links = data[cittaNorm]?.[quartiereNorm] ?? [];\r\n96|\r\n97|  // Push final results to dataset\r\n98|  await Actor.pushData({\r\n99|    zona: cittaNorm,\r\n100|    quartiere: quartiereNorm,\r\n101|    links,\r\n102|    count: links.length,\r\n103|    scrapedAt: new Date().toISOString(),\r\n104|  });\r\n105|\r\n106|  console.log(`[main] Completed. Pushed ${links.length} URLs to dataset.`);\r\n107|} catch (err) {\r\n108|  const errorMessage = err instanceof Error ? err.message : String(err);\r\n109|  console.error(`[main] Scraper failed: ${errorMessage}`);\r\n110|\r\n111|  // Fail the actor with error details\r\n112|  await Actor.fail({ statusMessage: errorMessage });\r\n113|} finally {\r\n114|  // Always close the browser cleanly\r\n115|  await browser.close();\r\n116|  console.log('[main] Browser closed.');\r\n117|}\r\n118|\r\n119|// Exit successfully\r\n120|await Actor.exit();",
