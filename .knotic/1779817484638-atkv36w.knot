      "content": "File: src/immobiliare-scraper.ts (213 lines) [hash:cb57c660]\n1|import type { Browser, Page } from 'playwright';\r\n2|import fs from 'node:fs';\r\n3|import path from 'node:path';\r\n4|\r\n5|/**\r\n6| * Step-by-step Playwright scraper for immobiliare.it listings.\r\n7| * Accepts a pre-configured browser instance (proxy already applied in main.ts).\r\n8| * Collects all listing URLs and stores them in the shared data dictionary.\r\n9| */\r\n10|\r\n11|/**\r\n12| * Check if the page contains a captcha indicator script.\r\n13| */\r\n14|export async function checkCaptcha(page: Page): Promise<boolean> {\r\n15|  try {\r\n16|    const content = await page.content();\r\n17|    return content.includes('ct.captcha-delivery.com');\r\n18|  } catch {\r\n19|    return false;\r\n20|  }\r\n21|}\r\n22|\r\n23|/**\r\n24| * Take a full-page screenshot and save to the specified path.\r\n25| * Creates directories as needed.\r\n26| */\r\n27|export async function takeScreenshot(page: Page, filePath: string): Promise<void> {\r\n28|  const dir = path.dirname(filePath);\r\n29|  fs.mkdirSync(dir, { recursive: true });\r\n30|  try {\r\n31|    await page.screenshot({ path: filePath, fullPage: true });\r\n32|  } catch (err) {\r\n33|    console.warn(`[screenshot] Failed to take screenshot: ${err}`);\r\n34|  }\r\n35|}\r\n36|\r\n37|export async function scrapeImmobiliare({\r\n38|  browser,\r\n39|  citta,\r\n40|  quartiere,\r\n41|  data,\r\n42|}: {\r\n43|  browser: Browser;\r\n44|  citta: string;\r\n45|  quartiere: string;\r\n46|  data: Record<string, Record<string, string[]>>;\r\n47|}): Promise<void> {\r\n48|  // Ensure screenshot directory exists\r\n49|  const screenshotDir = path.join('logs', citta, 'screenshots');\r\n50|  fs.mkdirSync(screenshotDir, { recursive: true });\r\n51|\r\n52|  // Build the entry URL\r\n53|  const taskUrl = `https://www.immobiliare.it/vendita-case/${encodeURIComponent(citta)}/${encodeURIComponent(quartiere)}/?criterio=rilevanza&tipoProprieta=1&noAste=1`;\r\n54|\r\n55|  // Create a new page (browser already has proxy)\r\n56|  const page = await browser.newPage();\r\n57|\r\n58|  try {\r\n59|    // Navigate to the listing page\r\n60|    await page.goto(taskUrl, { waitUntil: 'networkidle' });\r\n61|\r\n62|    // Initial wait to let content render\r\n63|    await page.waitForTimeout(15000);\r\n64|\r\n65|    // --- Captcha detection ---\r\n66|    if (await checkCaptcha(page)) {\r\n67|      const screenshotPath = path.join(screenshotDir, 'ip-block.png');\r\n68|      await takeScreenshot(page, screenshotPath);\r\n69|      throw new Error('Captcha detected – stopping to avoid IP block');\r\n70|    }\r\n71|\r\n72|    // --- Extract result count ---\r\n73|    let totalExpected: number | undefined;\r\n74|    try {\r\n75|      const resultText = await page.evaluate(() => {\r\n76|        const div = document.querySelector('div');\r\n77|        if (!div) return '';\r\n78|        // Find the div containing \"risultat\" text\r\n79|        const candidates = Array.from(document.querySelectorAll('div'));\r\n80|        for (const d of candidates) {\r\n81|          if (d.textContent && /risultat/i.test(d.textContent)) {\r\n82|            return d.textContent;\r\n83|          }\r\n84|        }\r\n85|        return '';\r\n86|      });\r\n87|\r\n88|      const match = resultText.match(/(\\d+)\\s*risultat/i);\r\n89|      if (match) {\r\n90|        totalExpected = parseInt(match[1], 10);\r\n91|        console.log(`[${citta}/${quartiere}] Risultati trovati: ${totalExpected}`);\r\n92|      }\r\n93|    } catch {\r\n94|      // Result count extraction failed – try to refresh once\r\n95|      console.log(`[${citta}/${quartiere}] Impossibile estrarre conteggio, refresh in corso...`);\r\n96|      await page.reload({ waitUntil: 'networkidle' });\r\n97|      await page.waitForTimeout(5000);\r\n98|\r\n99|      // Try again\r\n100|      const retryText = await page.evaluate(() => {\r\n101|        const candidates = Array.from(document.querySelectorAll('div'));\r\n102|        for (const d of candidates) {\r\n103|          if (d.textContent && /risultat/i.test(d.textContent)) {\r\n104|            return d.textContent;\r\n105|          }\r\n106|        }\r\n107|        return '';\r\n108|      });\r\n109|      const retryMatch = retryText.match(/(\\d+)\\s*risultat/i);\r\n110|      if (retryMatch) {\r\n111|        totalExpected = parseInt(retryMatch[1], 10);\r\n112|        console.log(`[${citta}/${quartiere}] Risultati dopo refresh: ${totalExpected}`);\r\n113|      } else {\r\n114|        // Still no result count – take screenshot and continue\r\n115|        const failPath = path.join(screenshotDir, 'no-data.png');\r\n116|        await takeScreenshot(page, failPath);\r\n117|        console.log(`[${citta}/${quartiere}] Impossibile trovare conteggio risultati. Screenshot salvato.`);\r\n118|      }\r\n119|    }\r\n120|\r\n121|    // --- Cookie banner ---\r\n122|    try {\r\n123|      await page.click('.didomi-continue-without-agreeing', { timeout: 5000 });\r\n124|      console.log(`[${citta}/${quartiere}] Banner cookie chiuso`);\r\n125|    } catch {\r\n126|      // Banner not present – continue silently\r\n127|    }\r\n128|\r\n129|    // --- Pagination loop ---\r\n130|    const allLinks: string[] = [];\r\n131|    let pageNum = 1;\r\n132|\r\n133|    while (true) {\r\n134|      console.log(`[${citta}/${quartiere}] Elaborazione pagina ${pageNum}`);\r\n135|\r\n136|      // Random scroll\r\n137|      const scrollY = pageNum === 1\r\n138|        ? Math.floor(Math.random() * (9500 - 7500 + 1)) + 7500\r\n139|        : Math.floor(Math.random() * (11500 - 9500 + 1)) + 9500;\r\n140|\r\n141|      await page.evaluate((y) => window.scrollTo(0, y), scrollY);\r\n142|      await page.waitForTimeout(Math.floor(Math.random() * (1500 - 500 + 1)) + 500);\r\n143|\r\n144|      // Extract listing links\r\n145|      const links = await page.evaluate(() => {\r\n146\n... [truncated 582 chars] ...\nine paginazione`);\r\n157|        break;\r\n158|      }\r\n159|\r\n160|      // Check if next button is disabled\r\n161|      const isDisabled = await nextBtn.evaluate(el => {\r\n162|        const parent = el.closest('div');\r\n163|        return parent?.getAttribute('aria-disabled') === 'true' || parent?.classList.contains('disabled');\r\n164|      });\r\n165|      if (isDisabled) {\r\n166|        console.log(`[${citta}/${quartiere}] Pulsante 'avanti' disabilitato – fine paginazione`);\r\n167|        break;\r\n168|      }\r\n169|\r\n170|      // Scroll before clicking next\r\n171|      const preScrollY = Math.floor(Math.random() * (7500 - 1500 + 1)) + 1500;\r\n172|      await page.evaluate((y) => window.scrollTo(0, y), preScrollY);\r\n173|      await page.waitForTimeout(800);\r\n174|\r\n175|      // Click next\r\n176|      await nextBtn.click();\r\n177|\r\n178|      // Try to close popup if it appears\r\n179|      try {\r\n180|        await page.click('.nd-dialogFrame__close', { timeout: 2000 });\r\n181|      } catch {\r\n182|        // No popup – continue\r\n183|      }\r\n184|\r\n185|      // Wait for new content to load\r\n186|      try {\r\n187|        await page.waitForSelector('a[class*=\"Title\"]', { timeout: 10000 });\r\n188|      } catch {\r\n189|        // New content didn't load within timeout – take screenshot and break\r\n190|        const errorPath = path.join(screenshotDir, `pagination-error-${pageNum}.png`);\r\n191|        await takeScreenshot(page, errorPath);\r\n192|        console.log(`[${citta}/${quartiere}] Timeout caricamento pagina ${pageNum + 1}. Screenshot salvato.`);\r\n193|        break;\r\n194|      }\r\n195|\r\n196|      pageNum++;\r\n197|    }\r\n198|\r\n199|    // --- Log warning if expected count doesn't match ---\r\n200|    if (totalExpected && allLinks.length < totalExpected * 0.9) {\r\n201|      console.warn(`[${citta}/${quartiere}] Attenzione: link raccolti (${allLinks.length}) < attesi (${totalExpected}). Controllare eventuali blocchi o pagine mancanti.`);\r\n202|    }\r\n203|\r\n204|    // --- Update shared dictionary ---\r\n205|    if (!data[citta]) data[citta] = {};\r\n206|    if (!data[citta][quartiere]) data[citta][quartiere] = [];\r\n207|    data[citta][quartiere].push(...allLinks);\r\n208|\r\n209|    console.log(`[${citta}/${quartiere}] Completato. Link totali memorizzati: ${allLinks.length}`);\r\n210|  } finally {\r\n211|    await page.close();\r\n212|  }\r\n213|}",
