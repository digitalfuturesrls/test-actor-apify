{
    "$schema": "https://apify.com/schemas/v1/input.ide.json",
    "title": "Immobiliare.it Scraper",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "citta": {
            "title": "Città",
            "type": "string",
            "description": "Nome della città (es. roma, milano)",
            "editor": "textfield",
            "minLength": 1,
            "maxLength": 100
        },
        "quartiere": {
            "title": "Quartiere",
            "type": "string",
            "description": "Nome del quartiere (es. parioli, navigli)",
            "editor": "textfield",
            "minLength": 1,
            "maxLength": 100
        }
    },
    "required": [
        "citta",
        "quartiere"
    ]
}