{
    "$schema": "https://apify.com/schemas/v1/input.ide.json",
    "title": "PlaywrightCrawler per immobiliare.it",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "citta": {
            "title": "Città",
            "type": "string",
            "description": "Città di riferimento da analizzare",
            "default" : "bologna"
        },
        "quartiere": {
            "title": "Quartiere",
            "type": "string",
            "description": "Quartiere della città da analizzare",
            "default" : "bolognina"
        },
        "maxRequestsPerCrawl": {
            "title": "Max Requests per Crawl",
            "type": "integer",
            "description": "Maximum number of requests that can be made by this crawler.",
            "default": 100
        }
    }
}
